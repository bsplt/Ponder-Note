{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ponder",
  "version": "1.0.3",
  "identifier": "io.github.pondernote",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ponder",
        "width": 1200,
        "height": 800,
        "backgroundColor": "#FFD35C",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
